# Copy to backend/.env and fill in. .env is gitignored; .env.example is tracked.

# ── Embeddings: OpenAI (direct) ──
# Used by the ingestion pipeline and the retriever. Reads this key directly.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── Chat LLM via Vercel AI Gateway (OpenAI-compatible) ──
# Satisfies the required "LLM gateway". Chat calls use these; embeddings do NOT.
# Confirm the exact base_url/key from your Vercel AI Gateway dashboard.
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
AI_GATEWAY_API_KEY=
CHAT_MODEL=gpt-4o
CHAT_MODEL_MINI=gpt-4o-mini

# ── Vector store: Qdrant Cloud ──
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=bake_me_up_recipes

# ── Web search tool (later) ──
TAVILY_API_KEY=

# ── LangSmith (paid — includes LangGraph Platform + tracing) ──
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=bake-me-up
